{
  "name": "multibro",
  "version": "0.1.0",
  "description": "CLI tool for managing browser-proxy bundles (bro = browser)",
  "type": "module",
  "bin": {
    "multibro": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "https-proxy-agent": "^7.0.6",
    "playwright": "^1.49.1",
    "prompts": "^2.4.2",
    "socks-proxy-agent": "^8.0.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
